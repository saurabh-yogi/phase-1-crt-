// Program -2 -- Encapsulation

class BankAccount {
public:
    int bankBalance;
    
    void setBalance(int amount){
        if(amount >= 0){
            bankBalance = amount;
        }else{
            cout << "enter valid amount";
        }
    }
    
    int getbalance() {
        return bankBalance;
    }
};

int main() {
    BankAccount obj1;
    obj1.setBalance(5000);
    cout << obj1.getbalance();
}
