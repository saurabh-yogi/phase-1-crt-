#include <iostream>
using namespace std;

// Program - 1 -- Types of Inherutance
// 1.1 -- Single Inheritance

class Vehicle{
public:    
    void start(){
        cout << "Vehicle starts" << "\n";
    }
};

class Car : public Vehicle {
public:
    void drive () {
        cout << "Car run" << "\n";
    }
};

int main(){
    Car obj1;
    obj1.drive();
    obj1.start();
}


// 1.2 -- Multilevel Inheritance

class Vehicle{
public:    
    void start(){
        cout << "Vehicle starts" << "\n";
    }
};

class Car : public Vehicle {
public:
    void drive () {
        cout << "Car run" << "\n";
    }
};

class Speedometer : public Car {
public:    
    void speed() {
        cout << "Car run at 60 km/h" << "\n";
    }
};

int main(){
    Speedometer obj1;
    obj1.drive();
    obj1.start();
    obj1.speed();
}


// Types -- 1.3 Hierarchical Inheritance

class Vehicle {
public:
    void start() {
        cout << "Vehicle starts" <<"\n";
    }
};
class Bike : public Vehicle {
public:
    void drive(){
        cout << "Bike is running" << "\n";
    }
};

class Car : public Vehicle {
public:
    void chalna() {
        cout << "Car is challing" << "\n";
    }
};
int main() {
    Car obj1;
    Bike obj2;
    
    obj1.start();
    obj1.chalna();
      
    obj2.start();
    obj2.drive();
}


