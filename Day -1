// PROGRAM 4
// SWAP VARIABLES VALUES

#include<iostream>
using namespace std;

int main() {
    int a, b;
    cin >> a >> b;
    
    // logic to swap VALUES
    
    int temp = a;
    a = b;
    b = temp;
    
    cout << a << "\n" << b << endl;
    return 0;
    
    
}


