// access specifier pritected

#include<iostream>
using namespace std;

class parent{
    protected:
    int secretcode = 1234;
};


class child : public parent{
    public:
    void accessLocker(){
    cout << secretcode;
}

};

int main(){
    child obj1;
    obj1.accessLocker();

}
        
    
    



