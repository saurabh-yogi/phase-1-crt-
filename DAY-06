// problem 5
// swapping with POINTERS

#include<iostream>
using namespace std;

void  swapno(int *ptr1, int *ptr2){
    int temp;
    temp = *ptr1;
    *ptr1 = *ptr2;
    *ptr2 = temp;
}
    
    int main(){
        int a,b;
        cin >> a;
        cin >> b;
      swapno(&a, &b);
        cout << a << " " << b ;
}

