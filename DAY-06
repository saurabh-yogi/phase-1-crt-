// program 3
// SMART AC REMOTE
#include<iostream>
using namespace std;

void setTemperature(){
    cout << "temp set to 22'C" << "\n";
}

void setTemperature(double temp){
    cout << "temp set to"<< temp << "'C" << "\n";
}

void setTemperature(string mode){
    if(mode == "eco"){
        cout << "temp set to 24'C" << "\n";
    } else if (mode == "turbo"){
        cout << "temp set to 18'C" << "\n";
    }
    
}



int main(){
    setTemperature();
    setTemperature(20.5);
    setTemperature("eco");
}


