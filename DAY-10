Leet Code -1  Two Sum
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        
        for(int i = 0; i < nums.size(); i++) {
            
            for(int j = i + 1; j < nums.size(); j++) {
                
                if(nums[i] + nums[j] == target) {
                    return {i, j};
                }
            }
        }
        
        return {};
    }
};


Leet code - 169 -- Majority Element
class Solution {
public:
    int majorityElement(vector<int>& nums) {
      int count = 0;
        int ans = 0;
        for(int i = 0; i < nums.size(); i++) {
            if(count == 0) {
                ans = nums[i];
            }
            if(ans == nums[i]) {
                count++;
            }
            else {
                count--;
            }
        }
    return ans;
    }
};
