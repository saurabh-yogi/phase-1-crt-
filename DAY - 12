// recursive function

#include<iostream>
using namespace std;

void printNumber(int number){
    // base condition
    if(number > 5){
        return;
    }
    
    
    // logic
    
    cout << number;
    printNumber(number+1);
}

int main(){
    printNumber(1);
}

