// factorial through recursion
#include<iostream>
using namespace std;


int factorial(int n){
    // base
    if(n == 0 || n == 1){
        return 1;
    }
    
    // logic
    return n * factorial(n-1);
}

int main(){
    cout << factorial(6);
}
