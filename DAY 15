// STACK 

#include<iostream>
#include<stack>
using namespace std;

int main(){
    int arr[] = {10,20,30,40,50};
    int n = 5;
    
    stack<int> st;
    
    // push data into stack
    for(int i = 0; i < n; i++){
        st.push(arr[i]);
    }
    
    // pop data from stack to array
    for(int i = 0; i< n; i++){
        arr[i] = st.top();
        st.pop();
    }
    
    cout << "reversed array..";
    for(int i = 0; i< n; i++){
        cout << arr[i] << " ";
    }
    return 0;
}


