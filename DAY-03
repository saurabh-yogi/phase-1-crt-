// problem 2
// factorial problem

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
     int fact = 1;
    
    for(int i = n; i >= 1; i--){
        fact = fact * i;
    }
        cout << fact ;
    
}
}

// problem 3
// prime number check

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    
    
    
    for(int i = 2; i <= n; i++){
        if (n % i == 0){
        cout << "not a prime no" ;
        break; 
    } else {
        cout << "prime no" ;
        break;
    }
    }
}
    


