// program 1
// call by value or refrence

#include<iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}

void updatebyRefrence(int &a){
    a = 500;
}

int main(){
    int original = 100;
    updatebyValue(original);
    cout << original << "\n";
    updatebyRefrence(original);
    cout << original ;
}

