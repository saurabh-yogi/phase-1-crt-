// program 4
// CONSTRUCTOR OVERLOADING

#include<iostream>
using namespace std;

class Rectangle{
    public:
    int length;
    int width;
    
    // default CONSTRUCTOR
    Rectangle(){
        length = 10;
        width = 6;
    }
    
    // parameterized CONSTRUCTOR
    Rectangle(int l){
        length = l;
        width = 7;
    }
    
    // parameterized CONSTRUCTOR
    Rectangle(int l, int b){
        length = l;
        width = b;
    }


void area(){
    cout << length * width << "\n";
}
};

int main(){
    Rectangle r1;
    r1.area();
    Rectangle r2(8);
    r2.area();
    Rectangle r3(4,6);
    r3.area();
}
